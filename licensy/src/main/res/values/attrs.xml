<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="LicensyView">

        <!--Text Color-->
        <attr name="lv_text_color_primary" format="color" />
        <attr name="lv_text_color_secondary" format="color" />
        <attr name="lv_text_color_link" format="color" />

        <!--Text Size-->
        <attr name="lv_text_size_title" format="dimension" />

        <!--Background-->
        <attr name="lv_background_color" format="color" />
        <attr name="lv_background_color_expand" format="color" />

        <!--Image-->
        <attr name="lv_open_image" format="reference" />
        <attr name="lv_image_tint" format="color" />

        <!--Divider-->
        <attr name="lv_divider_color" format="color" />

        <!--Style-->
        <attr name="lv_style" format="enum">
            <enum name="standard" value="0" />
            <enum name="compact" value="1" />
            <enum name="card" value="2" />
            <enum name="detailed" value="3" />
        </attr>

        <!--Interaction Mode-->
        <attr name="lv_interaction_mode" format="enum">
            <enum name="expand_inline" value="0" />
            <enum name="dialog" value="1" />
            <enum name="bottom_sheet" value="2" />
        </attr>

        <!--Card Style Properties-->
        <attr name="lv_card_corner_radius" format="dimension" />
        <attr name="lv_card_elevation" format="dimension" />

    </declare-styleable>

</resources>