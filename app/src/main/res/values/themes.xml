<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Licensy" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#6C63FF</item>
        <item name="colorPrimaryContainer">#E8E6FF</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">#1A1A1A</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#625B71</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSecondaryContainer">#1D192B</item>
        <!-- Background and surface -->
        <item name="android:colorBackground">#FAFAFA</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">#F3F3F3</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
